{
  "name": "glitchtip-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 -c development",
    "startssl": "ng serve --host 0.0.0.0 --ssl true",
    "start-prod-no-static": "ng serve --c prod-no-static",
    "build": "ng build",
    "build-prod": "ng build -c prod-no-static,production --deploy-url static/ --progress false",
    "build-static": "npx tsc buildStaticSite.ts --skipLibCheck && node buildStaticSite.js",
    "build-marketing": "ng build -c production --project marketing",
    "test": "ng test",
    "postinstall": "patch-package",
    "lint": "ng lint",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "concurrently \"npm run start -- --no-hmr\" \"wait-on http-get://localhost:4200 && npm run cy:run\" --kill-others --success first",
    "build-stats": "ng build -c production --stats-json",
    "analyze": "webpack-bundle-analyzer dist/glitchtip-frontend/stats.json",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "i18n": "npm run extract-i18n && npm run i18n-create-json",
    "extract-i18n": "ng extract-i18n",
    "i18n-create-json": "node bin/convert-xliff.js",
    "serve:ssr:marketing": "node dist/marketing/server/server.mjs",
    "storybook": "ng run glitchtip-frontend:storybook",
    "openapi-typescript": "openapi-typescript http://localhost:8000/api/openapi.json -o src/app/api/api-schema.d.ts --empty-objects-unknown",
    "openapi-typescript-allauth": "openapi-typescript http://localhost:8000/_allauth/openapi.json -o src/app/api/allauth-schema.d.ts"
  },
  "dependencies": {
    "@angular/animations": "~21.1.1",
    "@angular/cdk": "~21.1.1",
    "@angular/common": "~21.1.1",
    "@angular/compiler": "~21.1.1",
    "@angular/core": "~21.1.1",
    "@angular/forms": "~21.1.1",
    "@angular/material": "~21.1.1",
    "@angular/platform-browser": "~21.1.1",
    "@angular/platform-browser-dynamic": "~21.1.1",
    "@angular/platform-server": "~21.1.1",
    "@angular/router": "~21.1.1",
    "@angular/ssr": "^21.1.1",
    "@browser-logos/chrome": "^2.0.0",
    "@browser-logos/chromium": "^2.0.1",
    "@browser-logos/edge": "^2.0.7",
    "@browser-logos/firefox": "^3.0.10",
    "@browser-logos/internet-explorer-tile_10-11": "^1.0.13",
    "@browser-logos/opera": "^1.1.11",
    "@browser-logos/safari": "^2.1.0",
    "@browser-logos/safari-ios": "^1.0.15",
    "@egoistdeveloper/operating-system-logos": "~1.2.3",
    "@github/webauthn-json": "^2.1.1",
    "@micro-sentry/angular": "^7.2.0",
    "@stripe/stripe-js": "^8.6.0",
    "@swimlane/ngx-charts": "23.1.0",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "ngx-markdown": "^21.0.1",
    "ngx-mat-select-search": "^8.0.4",
    "openapi-fetch": "^0.15.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.1.1",
    "@angular-eslint/builder": "~21.1.0",
    "@angular-eslint/eslint-plugin": "~21.1.0",
    "@angular-eslint/eslint-plugin-template": "~21.1.0",
    "@angular-eslint/schematics": "~21.1.0",
    "@angular-eslint/template-parser": "~21.1.0",
    "@angular/build": "^21.1.1",
    "@angular/cli": "~21.1.1",
    "@angular/compiler-cli": "~21.1.1",
    "@angular/language-service": "~21.1.1",
    "@angular/localize": "~21.1.1",
    "@babel/core": "^7.7.2",
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@storybook/addon-docs": "~10.1.11",
    "@storybook/angular": "~10.1.11",
    "@types/d3": "^7.4.0",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^18.18.0",
    "@types/prismjs": "^1.26.0",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitest/mocker": "^4.0.16",
    "babel-loader": "^10.0.0",
    "concurrently": "^6.0.0",
    "cypress": "^15.8.1",
    "cypress-localstorage-commands": "^2.2.8",
    "eslint": "^9.0.0",
    "eslint-plugin-storybook": "^10.1.11",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "jasmine-core": "^5.0.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-extract-i18n-merge": "^3.2.1",
    "openapi-typescript": "^7.10.1",
    "patch-package": "^8.0.1",
    "prettier": "3.6.2",
    "storybook": "~10.1.11",
    "ts-loader": "^9.2.6",
    "ts-node": "~7.0.0",
    "typescript": "^5.9.2",
    "wait-on": "^5.3.0",
    "webpack": "^5.104.0",
    "xliff": "^6.2.2"
  },
  "overrides": {
    "@angular/animations": "$@angular/animations",
    "@angular/common": "$@angular/common",
    "@angular/compiler": "$@angular/compiler",
    "@angular/core": "$@angular/core",
    "@angular/forms": "$@angular/forms",
    "@angular/platform-browser": "$@angular/platform-browser",
    "@angular/platform-browser-dynamic": "$@angular/platform-browser-dynamic",
    "@angular/router": "$@angular/router",
    "@angular/cdk": "$@angular/cdk",
    "@angular/material": "$@angular/material",
    "rxjs": "$rxjs",
    "webpack": "$webpack"
  }
}
