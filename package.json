{
  "name": "glitchtip-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 -c development",
    "startssl": "ng serve --host 0.0.0.0 --ssl true",
    "start-prod-no-static": "ng serve --c prod-no-static",
    "build": "ng build",
    "build-prod": "ng build -c prod-no-static,production --deploy-url static/ --progress false",
    "build-static": "npx tsc buildStaticSite.ts --skipLibCheck && node buildStaticSite.js",
    "build-marketing": "ng build -c production --project marketing",
    "test": "ng test",
    "lint": "ng lint",
    "cy:open": "cypress open",
    "screenshot": "SCREENSHOT=true cypress run --spec cypress/integration/screenshot-run.ts --env screenshot=true",
    "cy:openscreenshot": "cypress open --env screenshot=true",
    "cy:run": "cypress run",
    "e2e": "concurrently \"npm run start\" \"wait-on http-get://localhost:4200 && npm run cy:run\" --kill-others --success first",
    "build-stats": "ng build --stats-json",
    "analyze": "webpack-bundle-analyzer dist/glitchtip-frontend/stats.json",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "extract-i18n": "ng extract-i18n",
    "i18n-create-json": "bin/xliff-to-json/xliff-to-json src/locale/ && mv src/locale/*.json src/assets/i18n/",
    "serve:ssr:marketing": "node dist/marketing/server/server.mjs",
    "storybook": "ng run glitchtip-frontend:storybook"
  },
  "dependencies": {
    "@angular/animations": "~19.0.5",
    "@angular/cdk": "~19.0.4",
    "@angular/common": "~19.0.5",
    "@angular/compiler": "~19.0.5",
    "@angular/core": "~19.0.5",
    "@angular/forms": "~19.0.5",
    "@angular/material": "~19.0.4",
    "@angular/platform-browser": "~19.0.5",
    "@angular/platform-browser-dynamic": "~19.0.5",
    "@angular/platform-server": "~19.0.5",
    "@angular/router": "~19.0.5",
    "@angular/ssr": "~19.0.6",
    "@browser-logos/chrome": "^2.0.0",
    "@browser-logos/chromium": "^2.0.1",
    "@browser-logos/edge": "^2.0.7",
    "@browser-logos/firefox": "^3.0.10",
    "@browser-logos/internet-explorer-tile_10-11": "^1.0.13",
    "@browser-logos/opera": "^1.1.11",
    "@browser-logos/safari": "^2.1.0",
    "@browser-logos/safari-ios": "^1.0.15",
    "@egoistdeveloper/operating-system-logos": "~1.2.3",
    "@github/webauthn-json": "^2.1.1",
    "@micro-sentry/angular": "^7.1.1",
    "@stripe/stripe-js": "^4.9.0",
    "@swimlane/ngx-charts": "^21.1.2",
    "date-fns": "^4.1.0",
    "express": "^4.18.2",
    "ngx-markdown": "^19.0.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~19.0.6",
    "@angular-eslint/builder": "~19.0.2",
    "@angular-eslint/eslint-plugin": "~19.0.2",
    "@angular-eslint/eslint-plugin-template": "~19.0.2",
    "@angular-eslint/schematics": "~19.0.2",
    "@angular-eslint/template-parser": "~19.0.2",
    "@angular/cli": "~19.0.6",
    "@angular/compiler-cli": "~19.0.5",
    "@angular/language-service": "~19.0.5",
    "@angular/localize": "~19.0.5",
    "@babel/core": "^7.7.2",
    "@chromatic-com/storybook": "^3.2.3",
    "@compodoc/compodoc": "^1.1.19",
    "@cypress/webpack-preprocessor": "^6.0.2",
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-onboarding": "^8.4.7",
    "@storybook/angular": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@types/d3": "^7.4.0",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/jasmine": "~3.3.8",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^18.18.0",
    "@types/prismjs": "^1.26.0",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "babel-loader": "^8.0.6",
    "concurrently": "^6.0.0",
    "cypress": "^13.13.3",
    "cypress-localstorage-commands": "^2.2.6",
    "eslint": "^8.0.0",
    "eslint-plugin-storybook": "^0.11.1",
    "jasmine-core": "^5.0.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-extract-i18n-merge": "^2.13.1",
    "storybook": "^8.4.7",
    "storybook-dark-mode": "^4.0.2",
    "ts-loader": "^9.2.6",
    "ts-node": "~7.0.0",
    "typescript": "^5.6.3",
    "wait-on": "^5.3.0",
    "webpack-bundle-analyzer": "^4.10.2",
    "xliff": "^6.2.1"
  },
  "overrides": {
    "@swimlane/ngx-charts": {
      "@angular/animations@": ">=18.0.0",
      "@angular/cdk@": ">=18.0.0",
      "@angular/common@": ">=18.0.0",
      "@angular/core@": ">=18.0.0",
      "@angular/forms@": ">=18.0.0",
      "@angular/platform-browser@": ">=18.0.0",
      "@angular/platform-browser-dynamic@": ">=18.0.0",
      "@angular/router@": ">=18.0.0"
    }
  }
}
