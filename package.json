{
  "name": "glitchtip-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 -c development",
    "startssl": "ng serve --host 0.0.0.0 --ssl true",
    "start-prod-no-static": "ng serve --c prod-no-static",
    "build": "ng build",
    "build-prod": "ng build -c prod-no-static,production --deploy-url static/ --progress false",
    "build-static": "npx tsc buildStaticSite.ts --skipLibCheck && node buildStaticSite.js",
    "build-marketing": "ng build -c production --project marketing && node scripts/inject-cli-version.js",
    "preview": "ng serve component-preview --host 0.0.0.0 --port 4300",
    "build-preview": "ng build component-preview",
    "test": "ng test",
    "lint": "ng lint",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "e2e": "concurrently \"npm run start -- --no-hmr\" \"wait-on http-get://localhost:4200 && npm run cy:run\" --kill-others --success first",
    "build-stats": "ng build -c production --stats-json",
    "analyze": "webpack-bundle-analyzer dist/glitchtip-frontend/stats.json",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "i18n": "npm run extract-i18n && npm run i18n-create-json",
    "extract-i18n": "ng extract-i18n",
    "i18n-create-json": "node bin/convert-xliff.js",
    "serve:ssr:marketing": "node dist/marketing/server/server.mjs",
    "openapi-typescript": "openapi-typescript http://localhost:8000/api/openapi.json -o src/app/api/api-schema.d.ts --empty-objects-unknown",
    "openapi-typescript-allauth": "openapi-typescript http://localhost:8000/_allauth/openapi.json -o src/app/api/allauth-schema.d.ts"
  },
  "dependencies": {
    "@angular/animations": "~22.0.1",
    "@angular/cdk": "~22.0.1",
    "@angular/common": "~22.0.1",
    "@angular/compiler": "~22.0.1",
    "@angular/core": "~22.0.1",
    "@angular/forms": "~22.0.1",
    "@angular/material": "~22.0.1",
    "@angular/platform-browser": "~22.0.1",
    "@angular/platform-browser-dynamic": "~22.0.1",
    "@angular/platform-server": "~22.0.1",
    "@angular/router": "~22.0.1",
    "@angular/ssr": "^22.0.1",
    "@browser-logos/chrome": "^2.0.0",
    "@browser-logos/chromium": "^2.0.1",
    "@browser-logos/edge": "^2.0.7",
    "@browser-logos/firefox": "^3.0.10",
    "@browser-logos/internet-explorer-tile_10-11": "^1.0.13",
    "@browser-logos/opera": "^1.1.11",
    "@browser-logos/safari": "^2.1.0",
    "@browser-logos/safari-ios": "^1.0.15",
    "@egoistdeveloper/operating-system-logos": "~1.2.3",
    "@github/webauthn-json": "^2.1.1",
    "@glitchtip/ng-charts": "^1.3.2",
    "@micro-sentry/angular": "^7.2.0",
    "@stripe/stripe-js": "^9.8.0",
    "date-fns": "^4.4.0",
    "express": "^4.18.2",
    "ngx-markdown": "^22.0.0",
    "ngx-mat-select-search": "^8.0.6",
    "openapi-fetch": "^0.17.0",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "~22.0.0",
    "@angular-eslint/schematics": "~22.0.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "~22.0.1",
    "@angular/compiler-cli": "~22.0.1",
    "@angular/language-service": "~22.0.1",
    "@angular/localize": "~22.0.1",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.0",
    "@types/prismjs": "^1.26.0",
    "@types/qrcode": "^1.5.5",
    "angular-eslint": "^22.0.0",
    "concurrently": "^6.0.0",
    "cypress": "^15.16.0",
    "cypress-localstorage-commands": "^2.3.0",
    "eslint": "^9.0.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "jsdom": "^25.0.1",
    "ng-extract-i18n-merge": "^3.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.0",
    "xliff": "^6.2.2"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    }
  }
}
